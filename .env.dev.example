# =============================================================================
# .env.dev.example — Pi Agent Hedge Fund
# =============================================================================
# Copy this file to .env and fill in your keys for the relevant phase.
# NEVER commit .env to git — it is gitignored.
#
# Phase guide:
#   Phase 1 (Current): Local Ollama only. No API keys needed.
#   Phase 2+:          Fill in data API keys (Finnhub, EODHD, Reddit).
#   Phase 4+:          Fill in broker and safety controls.
#   Phase 5 (Live):    Swap Alpaca Paper URL → live. Verify all controls.
# =============================================================================

# === LOCAL DEV (Phase 1 — Zero Cost) ===
# Ollama runs locally at this address. Do not change unless you moved the port.
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# The model loaded by start.sh and used by all agents in Phase 1.
# qwen3:8b at Q4_K_M quantization ≈ 5.2GB VRAM — within the 5.7GB ceiling.
# WARNING: Do not change to a larger model without verifying VRAM budget.
TRADINGAGENTS_QUICK_MODEL=qwen3:8b
TRADINGAGENTS_DEEP_MODEL=qwen3:8b

# === DATA APIs (Phase 2+) ===
# Register at https://finnhub.io — free tier: 60 calls/min
FINNHUB_API_KEY=

# Register at https://eodhd.com — provides EOD price + fundamental data
EODHD_API_KEY=

# Reddit API credentials for sentiment analysis agent
# Register at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=tradingagents/1.0 (by /u/YOUR_USERNAME)

# === BROKER (Phase 4+ — Paper Trading first) ===
# Register at https://alpaca.markets — Paper trading is free
# CRITICAL: Use paper URL below until Phase 5 is proven profitable.
# Switching to live URL with real money requires explicit Phase 4 gate passage.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# For Phase 5 live trading (DO NOT enable until paper trading is proven):
# ALPACA_BASE_URL=https://api.alpaca.markets

# === REMOTE LLM APIs (Phase 2+) ===
# OpenAI — used for Phase 2+ analyst nodes if routing away from Ollama
OPENAI_API_KEY=

# Anthropic — Claude Sonnet/Opus for Phase 4+ debaters and fund manager
ANTHROPIC_API_KEY=

# Google — Gemini Flash for Phase 2+ analyst nodes (large context, low cost)
GOOGLE_API_KEY=

# DeepSeek — cost-efficient alternative for Phase 3+ batch backtesting
DEEPSEEK_API_KEY=

# OpenRouter — unified gateway for multi-model routing in Phase 3+
OPENROUTER_API_KEY=

# === SAFETY CONTROLS (Phase 4+) ===
# Position cap: never allocate more than this fraction of account to one asset
MAX_POSITION_PCT=0.10

# Hard stop-loss: trailing stop percentage — bypasses AI entirely
STOP_LOSS_PCT=0.05

# Circuit breaker: halt the entire system if daily LLM API spend exceeds this
DAILY_API_SPEND_CAP_USD=10.00

# Hardcoded slippage for backtesting (Phase 3): degrades fill price by this %
# Range: 0.001 (0.1%) to 0.005 (0.5%). Default: 0.002 (0.2%)
BACKTEST_SLIPPAGE_PCT=0.002

# PDT guard: set to "margin" or "cash" — determines which rule applies
# margin: tracks 3-day-trades per rolling 5 business days (PDT rule)
# cash:   tracks T+1 settlement — never buys with unsettled funds
ACCOUNT_TYPE=cash
